@page "/CommunityAdmin"
@model Community.Pages.CommunityAdminModel

@{
    ViewData["Title"] = "Community Admin";
}

<!DOCTYPE html>
<html lang="da">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Community Admin</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(160deg, #FFFFFF 0%, #EDE5FF 50%, #D4C2F5 100%);
            min-height: 100vh;
            padding-bottom: 110px;
            color: #1a1a2e;
        }

        .hero {
            padding: 34px 18px 24px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            border-radius: 0 0 30px 30px;
            box-shadow: 0 12px 30px rgba(107,53,217,.25);
        }

            .hero h1 {
                font-size: 30px;
                margin-bottom: 8px;
            }

            .hero p {
                opacity: .9;
                font-size: 14px;
            }

        .content {
            padding: 18px 16px;
            max-width: 760px;
            margin: 0 auto;
        }

        .card, .post-card {
            background: rgba(255,255,255,.78);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.8);
            border-radius: 22px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: 0 8px 26px rgba(107,53,217,.10);
        }

        h2 {
            margin-bottom: 14px;
            font-size: 20px;
        }

        input, textarea, select {
            width: 100%;
            border: 1px solid rgba(107,53,217,.18);
            border-radius: 16px;
            padding: 12px;
            font-family: inherit;
            margin-bottom: 12px;
            background: rgba(255,255,255,.82);
            outline: none;
        }

        textarea {
            min-height: 120px;
            resize: vertical;
        }

        .btn-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        button {
            border: none;
            border-radius: 999px;
            padding: 12px 18px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            font-weight: 700;
            cursor: pointer;
        }

        .danger {
            background: linear-gradient(135deg, #d93434, #ff5a5a);
        }

        .post-header h3 {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .post-meta {
            display: flex;
            gap: 6px;
            font-size: 12px;
            color: #777;
            margin-bottom: 12px;
        }

        .post-content {
            font-size: 15px;
            line-height: 1.45;
            margin-bottom: 16px;
        }

        .status {
            background: rgba(255,255,255,.7);
            border-radius: 16px;
            padding: 14px;
            margin-bottom: 16px;
            color: #6B35D9;
            font-weight: 600;
        }

        .bottom-nav {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 32px);
            max-width: 420px;
            background: rgba(80,40,140,.55);
            backdrop-filter: blur(24px);
            border-radius: 32px;
            border: 1px solid rgba(200,160,255,.2);
            box-shadow: 0 8px 32px rgba(107,53,217,.3);
            padding: 12px 10px;
            display: flex;
            justify-content: space-around;
            z-index: 100;
        }

        .nav-item {
            text-decoration: none;
            color: rgba(230,220,255,.65);
            font-size: 11px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

            .nav-item.active {
                color: white;
            }

            .nav-item svg {
                width: 22px;
                height: 22px;
                stroke: currentColor;
                fill: none;
                stroke-width: 1.7;
            }
    </style>
</head>

<body>
    <div class="hero">
        <h1>Community Admin</h1>
        <p>Administrér opslag og feeds</p>
    </div>

    <main class="content">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status">
                @Model.StatusMessage
            </div>
        }

        <div class="card">
            <h2>Opret opslag</h2>

            <form method="post" action="/CommunityAdmin?handler=CreatePost">
                @Html.AntiForgeryToken()

                <select name="SelectedScope">
                    <option value="Global">Globalt opslag</option>
                    <option value="Center">Center opslag</option>
                </select>

                <input name="CenterId" placeholder="CenterId hvis center opslag" />

                <input name="NewPost.Title" placeholder="Titel" />

                <textarea name="NewPost.Content" placeholder="Skriv opslag..."></textarea>

                <div class="btn-row">
                    <button type="submit">
                        Publicér opslag
                    </button>
                </div>
            </form>
        </div>

        @foreach (var post in Model.Posts.OrderByDescending(p => p.CreatedAt))
        {
            <div class="post-card">
                <div class="post-header">
                    <h3>@post.Title</h3>

                    <div class="post-meta">
                        <span>@post.AuthorDisplayName</span>
                        <span>•</span>
                        <span>@post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                </div>

                <div class="post-content">
                    @post.Content
                </div>

                <form method="post" action="/CommunityAdmin?handler=DeletePost">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="PostId" value="@post.Id" />

                    <button type="submit" class="danger">
                        Slet opslag
                    </button>
                </form>
            </div>
        }
    </main>

    <nav class="bottom-nav">
        <a href="/Admin/Dashboard" class="nav-item">
            <svg viewBox="0 0 24 24">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            </svg>
            Hjem
        </a>

        <a href="/CommunityAdmin" class="nav-item active">
            <svg viewBox="0 0 24 24">
                <path d="M12 1l3 6 6 .9-4.5 4.4 1.1 6.2L12 16l-5.6 2.5 1.1-6.2L3 7.9 9 7z" />
            </svg>
            Admin
        </a>

        <a href="/Community" class="nav-item">
            <svg viewBox="0 0 24 24">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            Member
        </a>
    </nav>
</body>
</html>