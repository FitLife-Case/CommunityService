@page "/Community"
@model Community.Pages.CommunityModel

@{
    ViewData["Title"] = "Community";
}

<!DOCTYPE html>
<html lang="da">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Community</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(160deg, #FFFFFF 0%, #EDE5FF 50%, #D4C2F5 100%);
            min-height: 100vh;
            padding-bottom: 110px;
            color: #1a1a2e;
        }

        .hero {
            padding: 34px 18px 24px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            border-radius: 0 0 30px 30px;
            box-shadow: 0 12px 30px rgba(107,53,217,.25);
        }

            .hero h1 {
                font-size: 30px;
                margin-bottom: 8px;
            }

            .hero p {
                opacity: .9;
                font-size: 14px;
            }

        .content {
            padding: 18px 16px;
            max-width: 760px;
            margin: 0 auto;
        }

        .tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 16px;
        }

        .tab {
            border: none;
            border-radius: 999px;
            padding: 14px;
            background: rgba(255,255,255,.7);
            color: #6B35D9;
            font-weight: 700;
        }

            .tab.active {
                background: linear-gradient(135deg, #6B35D9, #9B72F0);
                color: white;
            }

        .card,
        .post-card {
            background: rgba(255,255,255,.78);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.8);
            border-radius: 22px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: 0 8px 26px rgba(107,53,217,.10);
        }

        .post-header h3 {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .post-meta {
            display: flex;
            gap: 6px;
            font-size: 12px;
            color: #777;
            margin-bottom: 12px;
        }

        .post-content {
            font-size: 15px;
            line-height: 1.45;
            margin-bottom: 16px;
        }

        .comment-box {
            margin-top: 12px;
        }

        textarea {
            width: 100%;
            border: 1px solid rgba(107,53,217,.18);
            border-radius: 16px;
            padding: 12px;
            font-family: inherit;
            margin-bottom: 10px;
            background: rgba(255,255,255,.82);
            outline: none;
            min-height: 90px;
        }

        button {
            border: none;
            border-radius: 999px;
            padding: 12px 18px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            font-weight: 700;
            cursor: pointer;
        }

        .empty {
            color: #777;
            font-size: 14px;
        }

        .bottom-nav {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 32px);
            max-width: 380px;
            background: rgba(80,40,140,.55);
            backdrop-filter: blur(24px);
            border-radius: 32px;
            border: 1px solid rgba(200,160,255,.2);
            box-shadow: 0 8px 32px rgba(107,53,217,.3);
            padding: 12px 10px;
            display: flex;
            justify-content: space-around;
            z-index: 100;
        }

        .nav-item {
            text-decoration: none;
            color: rgba(230,220,255,.65);
            font-size: 11px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

            .nav-item.active {
                color: white;
            }

            .nav-item svg {
                width: 22px;
                height: 22px;
                stroke: currentColor;
                fill: none;
                stroke-width: 1.7;
            }
    </style>
</head>

<body>
    <div class="hero">
        <h1>Community</h1>
        <p>@Model.CenterDisplayText</p>
    </div>

    <main class="content">
        <div class="tabs">
            <button class="tab active">
                Mit center
            </button>

            <button class="tab">
                Alle centre
            </button>
        </div>

        @if (!Model.MemberDataFound)
        {
            <div class="card">
                Dit center er ikke koblet endnu.
            </div>
        }

        @foreach (var post in Model.CenterPosts)
        {
            <div class="post-card">
                <div class="post-header">
                    <h3>@post.Title</h3>

                    <div class="post-meta">
                        <span>@post.AuthorDisplayName</span>
                        <span>•</span>
                        <span>@post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                </div>

                <div class="post-content">
                    @post.Content
                </div>
            </div>
        }

        @foreach (var post in Model.GlobalPosts)
        {
            <div class="post-card">
                <div class="post-header">
                    <h3>@post.Title</h3>

                    <div class="post-meta">
                        <span>@post.AuthorDisplayName</span>
                        <span>•</span>
                        <span>@post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                </div>

                <div class="post-content">
                    @post.Content
                </div>

                <div class="comment-box">
                    <form method="post" asp-page-handler="AddComment">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="PostId" value="@post.Id" />

                        <textarea asp-for="NewComment.Content"
                              placeholder="Skriv kommentar..."></textarea>

                        <button type="submit">
                            Kommentér
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.GlobalPosts.Any() && !Model.CenterPosts.Any())
        {
            <div class="card empty">
                Ingen opslag endnu.
            </div>
        }
    </main>

    <nav class="bottom-nav">
        <a href="/Member" class="nav-item">
            <svg viewBox="0 0 24 24">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            </svg>
            Hjem
        </a>

        <a href="/Community" class="nav-item active">
            <svg viewBox="0 0 24 24">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            Community
        </a>
    </nav>
</body>
</html>