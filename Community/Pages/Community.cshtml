@{
    ViewData["Title"] = "Community";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    :root {
        --primary: #7c3aed;
        --primary-light: #a78bfa;
        --bg: #f6f1ff;
        --card: #ffffff;
        --text: #241b35;
        --muted: #8b7ca7;
        --border: #e8dcff;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: var(--bg);
        font-family: Inter, sans-serif;
        color: var(--text);
    }

    .community-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 24px 20px 120px;
    }

    .hero {
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 28px;
        padding: 32px 24px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 16px 40px rgba(124, 58, 237, 0.25);
    }

        .hero h1 {
            margin: 0;
            font-size: 2.3rem;
            font-weight: 800;
        }

        .hero p {
            margin-top: 10px;
            opacity: 0.9;
        }

    .card {
        background: var(--card);
        border-radius: 24px;
        padding: 22px;
        margin-bottom: 18px;
        border: 1px solid var(--border);
        box-shadow: 0 8px 25px rgba(80, 50, 120, 0.06);
    }

        .card h2 {
            margin-top: 0;
            margin-bottom: 18px;
            font-size: 1.5rem;
        }

    input,
    select,
    textarea {
        width: 100%;
        border: 1px solid #ddd6fe;
        border-radius: 16px;
        padding: 14px 16px;
        font-size: 1rem;
        margin-bottom: 14px;
        background: #fff;
        color: var(--text);
    }

    textarea {
        resize: vertical;
        min-height: 120px;
    }

    button {
        border: none;
        border-radius: 16px;
        padding: 14px 22px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s ease;
        box-shadow: 0 8px 20px rgba(124, 58, 237, 0.25);
    }

        button:hover {
            transform: translateY(-2px);
        }

    .post {
        background: white;
        border-radius: 22px;
        padding: 20px;
        margin-bottom: 18px;
        border: 1px solid var(--border);
        box-shadow: 0 8px 20px rgba(80, 50, 120, 0.05);
    }

    .post-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
    }

    .post-title {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .post-meta {
        color: var(--muted);
        font-size: 0.9rem;
    }

    .post-content {
        line-height: 1.6;
        color: #3f315b;
    }

    .bottom-nav {
        position: fixed;
        left: 50%;
        bottom: 24px;
        transform: translateX(-50%);
        width: 360px;
        height: 72px;
        background: rgba(167, 139, 250, 0.78);
        backdrop-filter: blur(20px);
        border-radius: 999px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        box-shadow: 0 10px 30px rgba(124, 58, 237, 0.25);
        z-index: 999;
        border: 1px solid rgba(255,255,255,0.35);
    }

    .nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        color: rgba(255,255,255,0.75);
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 500;
        width: 72px;
        transition: all 0.2s ease;
    }

        .nav-item svg {
            width: 22px;
            height: 22px;
            stroke: currentColor;
            stroke-width: 2;
            fill: none;
        }

        .nav-item.active {
            color: white;
            font-weight: 700;
        }

        .nav-item:hover {
            color: white;
            transform: translateY(-2px);
        }

    @@media (max-width: 480px) {
        .bottom-nav {
            width: calc(100% - 32px);
            bottom: 16px;
        }

        .community-container {
            padding-left: 14px;
            padding-right: 14px;
        }
    }
</style>

<div class="community-container">

    <div class="hero">
        <h1>Community</h1>
        <p>Center feed · Center 2</p>
    </div>

    <div class="card">
        <h2>Vælg feed</h2>

        <select>
            <option>Center — bestemt hovedcenter</option>
        </select>

        <input type="text" value="2" />

        <button>Vis feed</button>
    </div>

    <div class="card">
        <h2>Opret opslag</h2>

        <select>
            <option>Center — bestemt hovedcenter</option>
        </select>

        <input type="text" value="2" />

        <input type="text" placeholder="Titel" />

        <textarea placeholder="Skriv noget til community..."></textarea>

        <button>Publicér opslag</button>
    </div>

    <div class="post">
        <div class="post-header">
            <div class="avatar">T</div>

            <div>
                <div class="post-title">Min første community post</div>
                <div class="post-meta">Posted by test-user · 16 May 2026 14:57</div>
            </div>
        </div>

        <div class="post-content">
            Det her er en community post for FitLife medlemmer 🎉
        </div>
    </div>
</div>

<nav class="bottom-nav">

    <a href="/Members/Dashboard" class="nav-item">
        <svg viewBox="0 0 24 24">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        Hjem
    </a>

    <a href="/Members/Aktivitet" class="nav-item">
        <svg viewBox="0 0 24 24">
            <polyline points="3 12 6 12 9 3 13 21 16 12 21 12"></polyline>
        </svg>
        Aktivitet
    </a>

    <a href="/Community?FeedScope=Center&FeedCenterId=2" class="nav-item active">
        <svg viewBox="0 0 24 24">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        Community
    </a>

    <a href="/booking" class="nav-item">
        <svg viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Hold
    </a>

    <a href="/Members/Profil" class="nav-item">
        <svg viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
        </svg>
        Profil
    </a>

</nav>