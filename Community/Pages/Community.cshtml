@page "/Community"
@model Community.Pages.CommunityfrontModel

@{
    ViewData["Title"] = "Community";
}

<!DOCTYPE html>
<html lang="da">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FitLife Community</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(160deg, #FFFFFF 0%, #EDE5FF 50%, #D4C2F5 100%);
            min-height: 100vh;
            padding-bottom: 110px;
            color: #1a1a2e;
        }

        .page {
            max-width: 760px;
            margin: 0 auto;
            padding: 24px 16px;
        }

        .top-card {
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            border-radius: 28px;
            padding: 28px 22px;
            box-shadow: 0 12px 34px rgba(107, 53, 217, 0.3);
            margin-bottom: 20px;
        }

            .top-card h1 {
                font-size: 30px;
                margin-bottom: 8px;
            }

            .top-card p {
                opacity: .9;
                font-size: 14px;
            }

        .glass-card {
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(14px);
            border-radius: 22px;
            border: 1px solid rgba(255,255,255,0.85);
            box-shadow: 0 6px 24px rgba(107,53,217,0.10);
            padding: 18px;
            margin-bottom: 16px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 14px;
        }

        .form-input,
        .form-select,
        .form-textarea {
            width: 100%;
            border: 1.5px solid rgba(160,120,240,0.25);
            background: rgba(255,255,255,0.75);
            border-radius: 14px;
            padding: 13px 14px;
            margin-bottom: 12px;
            font-size: 14px;
            outline: none;
            color: #1a1a2e;
        }

        .form-textarea {
            min-height: 95px;
            resize: vertical;
        }

            .form-input:focus,
            .form-select:focus,
            .form-textarea:focus {
                border-color: #6B35D9;
                box-shadow: 0 0 0 3px rgba(107,53,217,0.12);
            }

        .btn {
            border: none;
            border-radius: 14px;
            padding: 13px 18px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(107,53,217,0.25);
        }

        .post-card {
            border-left: 4px solid #6B35D9;
        }

        .post-title {
            font-size: 20px;
            margin-bottom: 6px;
        }

        .post-meta,
        .comment-meta {
            color: #777;
            font-size: 12px;
            margin-bottom: 12px;
        }

        .post-content {
            font-size: 15px;
            line-height: 1.5;
            margin-bottom: 16px;
        }

        .comments {
            border-top: 1px solid rgba(107,53,217,0.12);
            padding-top: 14px;
        }

        .comment {
            background: rgba(255,255,255,0.55);
            border-radius: 14px;
            padding: 12px;
            margin-bottom: 10px;
        }

        .empty {
            text-align: center;
            color: #777;
            padding: 28px 12px;
        }

        .bottom-nav {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 32px);
            max-width: 380px;
            background: rgba(80,40,140,0.55);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 32px;
            border: 1px solid rgba(200,160,255,0.2);
            box-shadow: 0 8px 32px rgba(107,53,217,0.3);
            padding: 12px 10px;
            display: flex;
            align-items: center;
            justify-content: space-around;
            z-index: 100;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            color: rgba(200,180,230,0.6);
            font-size: 11px;
            cursor: pointer;
            text-decoration: none;
            font-weight: 600;
        }

            .nav-item.active {
                color: white;
            }

            .nav-item svg {
                width: 22px;
                height: 22px;
                stroke: currentColor;
                fill: none;
                stroke-width: 1.6;
            }

        .nav-center {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #E040FB, #7B2FFF);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: -16px;
            box-shadow: 0 0 24px rgba(180,60,255,0.45);
            animation: pulse-ring 1.2s ease-in-out infinite;
        }

            .nav-center svg {
                width: 24px;
                height: 24px;
                stroke: white;
                fill: none;
                stroke-width: 1.6;
            }

        @@keyframes pulse-ring {
            0% {
                box-shadow: 0 0 0 0 rgba(180,60,255,0.7), 0 0 32px rgba(180,60,255,0.7);
            }

            70% {
                box-shadow: 0 0 0 20px rgba(180,60,255,0), 0 0 32px rgba(180,60,255,0.7);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(180,60,255,0), 0 0 32px rgba(180,60,255,0.7);
            }
        }
    </style>
</head>

<body>
    <div class="page">

        <section class="top-card">
            <h1>Community</h1>
            @if (Model.FeedScope == "Center")
            {
                <p>Center feed · Center @Model.FeedCenterId</p>
            }
            else
            {
                <p>Global feed · Alle brugere</p>
            }
        </section>

        <section class="glass-card">
            <div class="section-title">Vælg feed</div>

            <form method="get" action="/Community">
                <select name="FeedScope" class="form-select">
                    @if (Model.FeedScope == "Center")
                    {
                        <option value="Global">Global — alle brugere</option>
                        <option value="Center" selected>Center — bestemt hovedcenter</option>
                    }
                    else
                    {
                        <option value="Global" selected>Global — alle brugere</option>
                        <option value="Center">Center — bestemt hovedcenter</option>
                    }
                </select>

                <input type="text"
                       name="FeedCenterId"
                       value="@Model.FeedCenterId"
                       class="form-input"
                       placeholder="Center ID — fx 2" />

                <button type="submit" class="btn">Vis feed</button>
            </form>
        </section>

        <section class="glass-card">
            <div class="section-title">Opret opslag</div>

            <form method="post" action="/Community?handler=CreatePost">
                @Html.AntiForgeryToken()

                <input type="hidden" name="FeedScope" value="@Model.FeedScope" />
                <input type="hidden" name="FeedCenterId" value="@Model.FeedCenterId" />

                <select name="SelectedScope" class="form-select">
                    @if (Model.FeedScope == "Center")
                    {
                        <option value="Global">Global — alle brugere</option>
                        <option value="Center" selected>Center — bestemt hovedcenter</option>
                    }
                    else
                    {
                        <option value="Global" selected>Global — alle brugere</option>
                        <option value="Center">Center — bestemt hovedcenter</option>
                    }
                </select>

                <input type="text"
                       name="CenterId"
                       value="@Model.FeedCenterId"
                       class="form-input"
                       placeholder="Center ID — udfyld kun hvis Center vælges" />

                <input type="text"
                       name="NewPost.Title"
                       class="form-input"
                       placeholder="Titel" />

                <textarea name="NewPost.Content"
                          class="form-textarea"
                          placeholder="Skriv noget til community..."></textarea>

                <button type="submit" class="btn">Publicér opslag</button>
            </form>
        </section>

        @if (!Model.Posts.Any())
        {
            <section class="glass-card empty">
                Ingen opslag endnu.
            </section>
        }
        else
        {
            @foreach (var post in Model.Posts.OrderByDescending(p => p.CreatedAt))
            {
                <article class="glass-card post-card">
                    <h2 class="post-title">@post.Title</h2>

                    <div class="post-meta">
                        Posted by
                        @(string.IsNullOrWhiteSpace(post.AuthorDisplayName)
                                        ? post.AuthorUserId
                                        : post.AuthorDisplayName)
                · @post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
            </div>

                    <div class="post-content">@post.Content</div>

                    <div class="comments">
                        <div class="section-title">Kommentarer (@post.Comments.Count)</div>

                @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                        {
                            <div class="comment">
                                <div class="comment-meta">
                                    @(string.IsNullOrWhiteSpace(comment.AuthorDisplayName)
                                                            ? comment.AuthorUserId
                                                            : comment.AuthorDisplayName)
                        · @comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </div>
                    <div>@comment.Content</div>
                </div>
                                }

                        <form method="post" action="/Community?handler=AddComment">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="FeedScope" value="@Model.FeedScope" />
                            <input type="hidden" name="FeedCenterId" value="@Model.FeedCenterId" />
                            <input type="hidden" name="PostId" value="@post.Id" />

                            <textarea name="NewComment.Content"
                              class="form-textarea"
                              placeholder="Skriv en kommentar..."></textarea>

                            <button type="submit" class="btn">Tilføj kommentar</button>
                        </form>
                    </div>
                </article>
            }
        }
    </div>

    <nav class="bottom-nav">
        <a href="/Members/Dashboard" class="nav-item">
            <svg viewBox="0 0 24 24">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
            Hjem
        </a>

        <a href="/Members/Aktivitet" class="nav-item">
            <svg viewBox="0 0 24 24">
                <polyline points="3 12 6 12 9 3 13 21 16 12 21 12" />
            </svg>
            Aktivitet
        </a>

        <a href="/Community?FeedScope=Center&FeedCenterId=2" class="nav-center" aria-label="Community">
            <svg viewBox="0 0 24 24">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 9.9-1" />
            </svg>
        </a>

        <a href="/booking" class="nav-item">
            <svg viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            Hold
        </a>

        <a href="/Members/Profil" class="nav-item">
            <svg viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
            Profil
        </a>
    </nav>

</body>
</html>