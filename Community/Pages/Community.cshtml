@page "/Community"
@model Community.Pages.CommunityfrontModel

@{
    ViewData["Title"] = "Community";
}

<div class="community-container">
    <div class="hero">
        <h1>Community</h1>

        @if (Model.MemberDataFound)
        {
            <p>@Model.CenterDisplayText</p>
        }
        else
        {
            <p>Dit center er ikke koblet endnu</p>
        }
    </div>

    @if (!Model.Posts.Any())
    {
        <div class="card">
            <p>Der er ingen opslag endnu.</p>
        </div>
    }

    @foreach (var post in Model.Posts.OrderByDescending(p => p.CreatedAt))
    {
        <div class="post">
            <div class="post-title">@post.Title</div>

            <div class="post-meta">
                Posted by @post.AuthorDisplayName · @post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
            </div>

            <div class="post-content">@post.Content</div>

            @if (post.Comments.Any())
            {
                <div class="comments">
                    <h3>Kommentarer</h3>

                    @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                    {
                        <div class="comment">
                            <strong>@comment.AuthorDisplayName</strong>
                            <span>@comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                            <p>@comment.Content</p>
                        </div>
                    }
                </div>
            }

            <form method="post" asp-page-handler="AddComment">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="PostId" value="@post.Id" />

                <textarea asp-for="NewComment.Content" placeholder="Skriv en kommentar..."></textarea>

                <button type="submit">Kommentér</button>
            </form>
        </div>
    }
</div>