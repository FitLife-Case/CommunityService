@page "/Community"
@model Community.Pages.CommunityfrontModel

@{
    ViewData["Title"] = "Community";
}

<div class="community-page">

    <div class="community-header">
        <h1>Community</h1>

        @if (Model.FeedScope == "Center")
        {
            <p>Center feed · Center @Model.FeedCenterId</p>
        }
        else
        {
            <p>Global feed · Alle brugere</p>
        }
    </div>

    <div class="create-post-card">

        <form method="post" asp-page-handler="CreatePost">
            @Html.AntiForgeryToken()

            <input type="text"
                   name="NewPost.AuthorMemberId"
                   class="form-input"
                   placeholder="Member ID — midlertidigt indtil auth virker" />

            <select name="SelectedScope" class="form-select">
                @if (Model.FeedScope == "Center")
                {
                    <option value="Global">Global — alle brugere</option>
                    <option value="Center" selected>Center — bestemt hovedcenter</option>
                }
                else
                {
                    <option value="Global" selected>Global — alle brugere</option>
                    <option value="Center">Center — bestemt hovedcenter</option>
                }
            </select>

            <input type="text"
                   name="CenterId"
                   value="@Model.FeedCenterId"
                   class="form-input"
                   placeholder="Center ID — udfyld kun hvis du vælger Center" />

            <input type="text"
                   name="NewPost.Title"
                   class="form-input"
                   placeholder="Post title" />

            <textarea name="NewPost.Content"
                      class="form-textarea"
                      placeholder="Write something to the community..."></textarea>

            <button type="submit" class="btn-submit">
                Publish Post
            </button>
        </form>
    </div>

    <div class="posts-section">

        @if (!Model.Posts.Any())
        {
            <div class="empty-state">
                <p>Ingen opslag endnu.</p>
            </div>
        }
        else
        {
            @foreach (var post in Model.Posts)
            {
                <div class="post-card">

                    <div class="post-header">
                        <div>
                            <h2>@post.Title</h2>

                            <p class="post-meta">
                                Posted by
                                @(string.IsNullOrWhiteSpace(post.AuthorDisplayName)
                                                        ? post.AuthorUserId
                                                        : post.AuthorDisplayName)
                    </p>

                            <p class="post-date">
                                @post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </p>
                        </div>
                    </div>

                    <div class="post-content">
                        <p>@post.Content</p>
                    </div>

                    <div class="comments-section">

                        <h3>Comments</h3>

                @if (!post.Comments.Any())
                        {
                            <p>Ingen kommentarer endnu.</p>
                        }
                        else
                        {
                            @foreach (var comment in post.Comments)
                            {
                                <div class="comment">

                                    <p class="comment-author">
                                        @(string.IsNullOrWhiteSpace(comment.AuthorDisplayName)
                                                                ? comment.AuthorUserId
                                                                : comment.AuthorDisplayName)
                    </p>

                                    <p>@comment.Content</p>

                                    <p class="comment-date">
                                        @comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                    </p>
                                </div>
                                }
                        }

                        <form method="post" asp-page-handler="AddComment">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="PostId"
                                   value="@post.Id" />

                            <input type="text"
                                   name="NewComment.AuthorMemberId"
                                   class="form-input"
                                   placeholder="Member ID" />

                            <textarea name="NewComment.Content"
                              class="form-textarea"
                              placeholder="Write a comment..."></textarea>

                            <button type="submit" class="btn-submit">
                                Add Comment
                            </button>

                        </form>

                    </div>

                </div>
            }
        }

    </div>

</div>