@page "/Community"
@model Community.Pages.CommunityfrontModel

@{
    ViewData["Title"] = "Community";
}

<!DOCTYPE html>
<html lang="da">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Community</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(160deg, #FFFFFF 0%, #EDE5FF 50%, #D4C2F5 100%);
            min-height: 100vh;
            padding-bottom: 110px;
            color: #1a1a2e;
        }

        .hero {
            padding: 34px 18px 24px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            border-radius: 0 0 30px 30px;
            box-shadow: 0 12px 30px rgba(107,53,217,.25);
        }

            .hero h1 {
                font-size: 30px;
                margin-bottom: 8px;
            }

            .hero p {
                opacity: .9;
                font-size: 14px;
            }

        .content {
            padding: 18px 16px;
            max-width: 760px;
            margin: 0 auto;
        }

        .feed-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 18px;
        }

        .feed-tab {
            border: none;
            border-radius: 18px;
            padding: 13px 12px;
            background: rgba(255,255,255,.72);
            color: #6B35D9;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 6px 18px rgba(107,53,217,.08);
        }

            .feed-tab.active {
                background: linear-gradient(135deg, #6B35D9, #9B72F0);
                color: white;
            }

        .feed-section {
            display: none;
        }

            .feed-section.active {
                display: block;
            }

        .card, .post-card {
            background: rgba(255,255,255,.78);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.8);
            border-radius: 22px;
            padding: 18px;
            margin-bottom: 14px;
            box-shadow: 0 8px 26px rgba(107,53,217,.10);
        }

        .post-header h3 {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .post-meta {
            display: flex;
            gap: 6px;
            font-size: 12px;
            color: #777;
            margin-bottom: 12px;
        }

        .post-content {
            font-size: 15px;
            line-height: 1.45;
            margin-bottom: 14px;
        }

        .comments-section {
            margin-top: 14px;
            padding-top: 12px;
            border-top: 1px solid rgba(107,53,217,.12);
        }

            .comments-section h4 {
                font-size: 14px;
                margin-bottom: 10px;
            }

        .comment-card {
            background: rgba(107,53,217,.06);
            border-radius: 14px;
            padding: 10px;
            margin-bottom: 8px;
        }

        .comment-header {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            font-size: 12px;
            margin-bottom: 6px;
        }

            .comment-header span {
                color: #777;
                font-size: 11px;
            }

        .comment-content {
            font-size: 14px;
        }

        textarea {
            width: 100%;
            min-height: 70px;
            resize: vertical;
            border: 1px solid rgba(107,53,217,.18);
            border-radius: 16px;
            padding: 12px;
            font-family: inherit;
            outline: none;
            margin-bottom: 10px;
            background: rgba(255,255,255,.8);
        }

        button {
            border: none;
            border-radius: 999px;
            padding: 10px 16px;
            background: linear-gradient(135deg, #6B35D9, #9B72F0);
            color: white;
            font-weight: 700;
            cursor: pointer;
        }

        .bottom-nav {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 32px);
            max-width: 380px;
            background: rgba(80,40,140,.55);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 32px;
            border: 1px solid rgba(200,160,255,.2);
            box-shadow: 0 8px 32px rgba(107,53,217,.3);
            padding: 12px 10px;
            display: flex;
            justify-content: space-around;
            z-index: 100;
        }

        .nav-item {
            text-decoration: none;
            color: rgba(230,220,255,.65);
            font-size: 11px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

            .nav-item.active {
                color: white;
            }

            .nav-item svg {
                width: 22px;
                height: 22px;
                stroke: currentColor;
                fill: none;
                stroke-width: 1.7;
            }
    </style>
</head>

<body>
    <div class="hero">
        <h1>Community</h1>
        <p>@Model.CenterDisplayText</p>
    </div>

    <main class="content">
        <div class="feed-tabs">
            <button type="button" class="feed-tab active" onclick="showFeed('center')">Mit center</button>
            <button type="button" class="feed-tab" onclick="showFeed('all')">Alle centre</button>
        </div>

        <section id="feed-center" class="feed-section active">
            @if (!Model.MemberDataFound)
            {
                <div class="card">
                    <p>Dit center er ikke koblet endnu.</p>
                </div>
            }
            else if (!Model.CenterPosts.Any())
            {
                <div class="card">
                    <p>Der er ingen opslag i dit center endnu.</p>
                </div>
            }

            @foreach (var post in Model.CenterPosts.OrderByDescending(p => p.CreatedAt))
            {
                <div class="post-card">
                    <div class="post-header">
                        <h3>@post.Title</h3>
                        <div class="post-meta">
                            <span>@post.AuthorDisplayName</span>
                            <span>•</span>
                            <span>@post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                    </div>

                    <div class="post-content">@post.Content</div>

                    @if (post.Comments.Any())
                    {
                        <div class="comments-section">
                            <h4>Kommentarer</h4>

                            @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                            {
                                <div class="comment-card">
                                    <div class="comment-header">
                                        <strong>@comment.AuthorDisplayName</strong>
                                        <span>@comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                                    </div>
                                    <div class="comment-content">@comment.Content</div>
                                </div>
                            }
                        </div>
                    }

                    <form method="post" asp-page-handler="AddComment">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="PostId" value="@post.Id" />

                        <textarea name="NewComment.Content" placeholder="Skriv en kommentar..." required></textarea>

                        <button type="submit">Kommentér</button>
                    </form>
                </div>
            }
        </section>

        <section id="feed-all" class="feed-section">
            @if (!Model.GlobalPosts.Any())
            {
                <div class="card">
                    <p>Der er ingen opslag endnu.</p>
                </div>
            }

            @foreach (var post in Model.GlobalPosts.OrderByDescending(p => p.CreatedAt))
            {
                <div class="post-card">
                    <div class="post-header">
                        <h3>@post.Title</h3>
                        <div class="post-meta">
                            <span>@post.AuthorDisplayName</span>
                            <span>•</span>
                            <span>@post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                    </div>

                    <div class="post-content">@post.Content</div>

                    @if (post.Comments.Any())
                    {
                        <div class="comments-section">
                            <h4>Kommentarer</h4>

                            @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                            {
                                <div class="comment-card">
                                    <div class="comment-header">
                                        <strong>@comment.AuthorDisplayName</strong>
                                        <span>@comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                                    </div>
                                    <div class="comment-content">@comment.Content</div>
                                </div>
                            }
                        </div>
                    }

                    <form method="post" asp-page-handler="AddComment">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="PostId" value="@post.Id" />

                        <textarea name="NewComment.Content" placeholder="Skriv en kommentar..." required></textarea>

                        <button type="submit">Kommentér</button>
                    </form>
                </div>
            }
        </section>
    </main>

    <nav class="bottom-nav">
        <a href="/Members/Dashboard" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>
            Hjem
        </a>

        <a href="/Community" class="nav-item active">
            <svg viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H7l-4 4V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z" /></svg>
            Community
        </a>

        <a href="/BookingList" class="nav-item">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            Hold
        </a>

        <a href="/Members/Profil" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
            Profil
        </a>
    </nav>

    <script>
        function showFeed(feed) {
            document.querySelectorAll('.feed-tab').forEach(x => x.classList.remove('active'));
            document.querySelectorAll('.feed-section').forEach(x => x.classList.remove('active'));

            if (feed === 'center') {
                document.querySelectorAll('.feed-tab')[0].classList.add('active');
                document.getElementById('feed-center').classList.add('active');
            } else {
                document.querySelectorAll('.feed-tab')[1].classList.add('active');
                document.getElementById('feed-all').classList.add('active');
            }
        }
    </script>
</body>
</html>