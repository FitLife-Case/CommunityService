<?xml version="1.0" encoding="utf-8" ?>

<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<extensions>
		<add assembly="NLog.Targets.Loki" />
	</extensions>

	<targets>
		<target xsi:type="Console"
				name="console"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<target xsi:type="Loki"
				name="loki"
				endpoint="${configsetting:name=Loki:Url}">
			<label name="service" layout="community-service" />
			<label name="level" layout="${level}" />
		</target>
	</targets>

	<rules>
		<logger name="*" minlevel="Info" writeTo="console,loki" />
	</rules>

</nlog>